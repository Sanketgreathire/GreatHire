# ============================================
# AUTO-SOURCING CONFIGURATION
# ============================================

# GitHub Personal Access Token (Optional but Recommended)
# Get from: https://github.com/settings/tokens
# Scopes needed: public_repo, read:user
# Without token: 60 requests/hour
# With token: 5,000 requests/hour
GITHUB_TOKEN=

# Cron Schedule for Auto-Sourcing
# Format: minute hour day month weekday
# Default: 0 3 * * * (3:00 AM daily)
# Examples:
#   - Every 6 hours: 0 */6 * * *
#   - Every Monday at 9 AM: 0 9 * * 1
#   - Twice daily (6 AM & 6 PM): 0 6,18 * * *
AUTO_SOURCING_SCHEDULE=0 3 * * *

# ============================================
# EXISTING CONFIGURATION (keep your current values)
# ============================================

# Add your existing environment variables below
# PORT=8000
# MONGO_URI=...
# etc.
