AI_SERVICE_PORT=8001
AI_SERVICE_HOST=0.0.0.0

# Embedding model — all-MiniLM-L6-v2 is fast (80ms) and accurate (384 dims)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Qdrant vector database
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=sourcing_candidates

# API key for securing AI service (Node.js uses this)
AI_SERVICE_API_KEY=greathire-ai-secret-key-change-in-prod

# Batch size for embedding generation
EMBEDDING_BATCH_SIZE=32
